# Banco de dados
POSTGRES_USER=financas_user
POSTGRES_PASSWORD=troque_esta_senha
DATABASE_URL=postgresql+asyncpg://financas_user:troque_esta_senha@postgres:5432/financas

# JWT Auth (financas-api)
JWT_SECRET_KEY=gere_uma_chave_aleatoria_com_openssl_rand_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Usuário administrador (seed na primeira migration)
ADMIN_USERNAME=klayton
ADMIN_PASSWORD=troque_esta_senha

# OpenAI (ia-api)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1
OPENAI_MODEL_MINI=gpt-4.1-mini

# DeepSeek fallback (ia-api — NR-02)
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# CORS (domínio do VPS em produção)
ALLOWED_ORIGINS=https://seudominio.com,http://localhost:3000

# URL interna da ia-api (usado pelo financas-api para resumo narrativo)
IA_API_URL=http://ia-api:8002

# Portas expostas no host (altere se conflitar com outros serviços)
HTTP_PORT=8765
HTTPS_PORT=4443
FINANCAS_API_PORT=18001
IA_API_PORT=18002

# Discord Bot (opcional — remova o serviço do docker-compose se não usar)
DISCORD_BOT_TOKEN=seu_token_aqui
DISCORD_ALLOWED_USER_ID=seu_discord_user_id
DISCORD_CHANNEL_ID=id_do_canal
